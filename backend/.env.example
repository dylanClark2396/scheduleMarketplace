# Copy to .env and fill in values
# These are loaded by the EC2 instance from SSM at deploy time — only needed for local dev

COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
S3_IMPORT_BUCKET=schedule-marketplace-imports-prod-123456789012
S3_SCRAPER_BUCKET=schedule-marketplace-scraper-prod-123456789012
AWS_REGION=us-east-1
NODE_ENV=development
